# ========================================
# AMBIENTE
# ========================================
NODE_ENV=development
PORT=3000

# ========================================
# BANCO DE DADOS - MySQL
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=senha_root
DB_NAME=crm_saas_db
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_CHARSET=utf8mb4
DB_TIMEZONE=+00:00

# ========================================
# JWT - Autenticação
# ========================================
JWT_SECRET=sua_secret_jwt_super_segura_aqui_min_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=sua_refresh_secret_super_segura_aqui_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# BCRYPT
# ========================================
BCRYPT_ROUNDS=10

# ========================================
# REDIS - Cache (opcional)
# ========================================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ========================================
# EMAIL - Nodemailer
# ========================================
MAIL_ENABLED=true
MAIL_FROM=noreply@crm-saas.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu_email@gmail.com
MAIL_PASSWORD=sua_app_password
MAIL_SECURE=false

# ========================================
# UPLOAD - Multer
# ========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_MIMETYPES=image/jpeg,image/png,image/gif,application/pdf

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESS_REQUESTS=false

# ========================================
# CORS
# ========================================
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
CORS_CREDENTIALS=true

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# ========================================
# API
# ========================================
API_VERSION=v1
API_URL=http://localhost:3000

# ========================================
# PAGINAÇÃO DEFAULT
# ========================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ========================================
# TIMEZONE
# ========================================
TIMEZONE=America/Sao_Paulo